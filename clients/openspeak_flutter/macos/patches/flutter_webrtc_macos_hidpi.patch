+      self.restartAttempt = 0;
+    }
+    self.restartInProgress = YES;
+    NSLog(@"ScreenCaptureKit capture stopped unexpectedly: %@; scheduling recovery", error);
+    [self scheduleRestartForGeneration:self.captureGeneration];
+  });
+}
