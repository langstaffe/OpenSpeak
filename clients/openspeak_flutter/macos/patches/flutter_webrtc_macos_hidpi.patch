+- (void)scheduleRestartForGeneration:(NSUInteger)generation API_AVAILABLE(macos(12.3)) {
+  static const NSTimeInterval delays[] = {0.5, 1.0, 2.0};
+  if (self.restartAttempt >= sizeof(delays) / sizeof(delays[0])) {
+    self.restartInProgress = NO;
+    NSLog(@"ScreenCaptureKit recovery failed after %lu attempts", (unsigned long)self.restartAttempt);
+    return;
+  }
+
+  NSTimeInterval delay = delays[self.restartAttempt++];
+  dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(delay * NSEC_PER_SEC)),
+                 self.captureQueue, ^{
+    if (generation != self.captureGeneration || self.userStopping || self.stream != nil) {
+      return;
+    }
+    [self startStreamForGeneration:generation completion:^(NSError * _Nullable error) {
+      if (generation != self.captureGeneration || self.userStopping) {
+        return;
+      }
+      if (error != nil) {
+        NSLog(@"ScreenCaptureKit recovery attempt %lu failed: %@",
+              (unsigned long)self.restartAttempt, error);
+        [self scheduleRestartForGeneration:generation];
+        return;
+      }
+      self.restartAttempt = 0;
+      self.restartInProgress = NO;
+      NSLog(@"ScreenCaptureKit capture recovered");
+    }];
+  });
+}
