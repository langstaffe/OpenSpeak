OS_ADDR=127.0.0.1:27411
OS_DATABASE_PATH=/var/lib/openspeak/openspeak.db
OS_FILE_ROOT=/var/lib/openspeak/files
OS_DIRECT_FILE_ROOT=/var/lib/openspeak/tmp/direct_files
OS_LOG_FILE=/var/log/openspeak/openspeak.log
OS_LOG_LEVEL=info
OS_JWT_SECRET=change-this-to-a-long-random-secret
OS_JWT_TTL_SECONDS=86400
OS_DEFAULT_ENCRYPTION_MODE=none
OS_DEFAULT_HISTORY_RETENTION_DAYS=30
OS_CADDY_ADMIN_URL=unix:///var/lib/openspeak/caddy/admin.sock
OS_CADDY_CONFIG_PATH=/var/lib/openspeak/caddy/Caddyfile
OS_TLS_VERIFY_ADDR=127.0.0.1:27412
OS_TLS_BACKEND_UPSTREAM=127.0.0.1:27411
OS_TLS_LIVEKIT_UPSTREAM=127.0.0.1:27420
OS_PLAIN_PUBLIC_PORT=27410
OS_TLS_PUBLIC_PORT=27412

# Optional fallback for development or when no media node is configured.
# Production relay voice/screen sharing should use the per-server media_nodes API
# so a high-bandwidth LiveKit server can be changed without editing this file.
# OS_LIVEKIT_URL=wss://livekit.example.com
# OS_LIVEKIT_API_KEY=your-livekit-api-key
# OS_LIVEKIT_API_SECRET=your-livekit-api-secret
# OS_LIVEKIT_TOKEN_TTL_SECONDS=3600
